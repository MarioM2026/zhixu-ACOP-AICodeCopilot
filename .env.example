# 知墟 ACOP 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============= 基础配置 =============
NODE_ENV=production
PORT=3001
TZ=Asia/Shanghai
LOG_LEVEL=info

# ============= 钉钉告警 =============
# 钉钉群机器人的 Webhook 地址（格式：https://oapi.dingtalk.com/robot/send?access_token=xxx）
DINGTALK_WEBHOOK=

# ============= 邮件告警 =============
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
ALERT_EMAIL=alerts@example.com

# ============= 首次启动向导 =============
# 设置为 "true" 跳过首次启动向导（已配置完成后设为 true）
SKIP_INSTALLER=false
