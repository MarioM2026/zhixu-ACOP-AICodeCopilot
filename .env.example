# OpenTelemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=zhixu-development
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_URL=sqlite:///./data/zhixu.db
# For PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/zhixu

# Grafana Configuration
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus Configuration
PROMETHEUS_PORT=9090

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379

# Alert Configuration
ALERT_ENABLED=true
ALERT_DINGTALK_WEBHOOK=
ALERT_EMAIL_HOST=
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=
ALERT_EMAIL_PASSWORD=

# Security
API_KEY_SALT=your-salt-here
ENCRYPTION_KEY=your-encryption-key

# Feature Flags
FEATURE_MULTI_TENANT=false
FEATURE_AI_SUGGESTION=false
