# ========================
# 🚫 敏感信息保护 - 禁止上传
# ========================

# 本地配置文件（可能包含邮箱、密码、密钥）
config.local.*
config.private.*
*.local.*
*private*

# 环境变量文件（所有 .env 开头的文件，除模板外）
*.env
!.env.example

# 密钥与凭证文件
*.key
*.pem
*.p12
*.pfx
*.pub

# 缓存文件
.cache/
.temp/
.tmp/

# Node.js 缓存
.npm
.eslintcache

# 本地运行时产物
*.local.json
local-*.json

# Travis / CI 相关（如本地调试时产生的文件）
.travis/
.vercel/
.next/

